{
    "name": "lalalili/laravelshoppingcart",
    "description": "Shopping cart package for Laravel 11/12 with PHP 8.3+ support.",
    "version": "13.0.0",
    "type": "library",
    "keywords": [
        "laravel",
        "shopping cart",
        "cart",
        "ecommerce"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "James Liang",
            "email": "lalalili@gmail.com"
        }
    ],
    "support": {
        "source": "https://github.com/lalalili/laravelshoppingcart",
        "issues": "https://github.com/lalalili/laravelshoppingcart/issues"
    },
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/translation": "^11.0|^12.0",
        "illuminate/validation": "^11.0|^12.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0|^10.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Lalalili\\ShoppingCart\\": "src/Lalalili/ShoppingCart/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lalalili\\ShoppingCart\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "Lalalili\\ShoppingCart\\ShoppingCartServiceProvider"
            ],
            "aliases": {
                "ShoppingCart": "Lalalili\\ShoppingCart\\Facades\\ShoppingCartFacade"
            }
        }
    },
    "scripts": {
        "test": "phpunit --configuration=phpunit.xml",
        "analyse": "phpstan analyse --configuration=phpstan.neon.dist --no-progress"
    },
    "config": {
        "sort-packages": true
    }
}
